{
  "name": "springboot-example",
  "image": "698995615062.dkr.ecr.ap-south-2.amazonaws.com/mydockerhub/springboot-example:latest",
  "cpu": "1024",
  "memory": "3072",
  "portMappings": [
    {
      "containerPort": 9999,
      "hostPort": 9999,
      "protocol": "tcp",
      "name": "springboot-example-9999-tcp",
      "appProtocol": "http"
    }
  ],
  "essential": true,
  "environment": [],
  "environmentFiles": [],
  "mountPoints": [],
  "volumesFrom": [],
  "ulimits": [],
  "logConfiguration": {
    "logDriver": "awslogs",
    "options": {
      "awslogs-group": "/ecs/my-springboot-task-definition",
      "awslogs-create-group": "true",
      "awslogs-region": "ap-south-2",
      "awslogs-stream-prefix": "ecs"
    },
    "secretOptions": []
  },
  "systemControls": []
}